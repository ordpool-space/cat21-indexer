# Runtime
NODE_ENV=development
PORT=3333

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/cat21

# ord REST API base URL
ORD_API_URL=https://ord.cat21.space

# Sync interval (ms) — how often to poll ord for new cats
SYNC_INTERVAL_MS=60000

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:4200,https://cat21.space
